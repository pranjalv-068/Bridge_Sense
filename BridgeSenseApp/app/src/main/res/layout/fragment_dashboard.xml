<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@dimen/spacing_md">

    <!-- Overall Bridge Health Score -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardBridgeHealth"
        style="@style/BridgeSense.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/accent_cyan_alpha"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="@string/bridge_health_label"
                android:textColor="@color/accent_cyan"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvHealthScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="100%"
                android:textColor="@color/accent_cyan"
                android:textSize="48sp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvNodesTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_lg"
        android:fontFamily="sans-serif-medium"
        android:text="@string/nodes_active_label"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/cardBridgeHealth"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvMockBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_connection_pill"
        android:backgroundTint="@color/accent_purple_dim"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:text="@string/mock_badge"
        android:textColor="@color/text_primary"
        android:textSize="10sp"
        android:textStyle="bold"
        android:visibility="gone"
        tools:visibility="visible"
        app:layout_constraintBottom_toBottomOf="@id/tvNodesTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvNodesTitle" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvNodes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/spacing_md"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvNodesTitle"
        tools:listitem="@layout/item_node" />

</androidx.constraintlayout.widget.ConstraintLayout>
