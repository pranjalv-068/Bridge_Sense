<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Live Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/viewFinder"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Annotated ImageView (shown after capture) -->
    <ImageView
        android:id="@+id/ivCaptured"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <!-- Overlay for drawing YOLOX bounding boxes -->
    <com.bridgesense.app.ui.camera.OverlayView
        android:id="@+id/overlayView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top Status Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/scrim"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvModelStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_connection_pill"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="@string/camera_yolox_ready"
            android:textColor="@color/accent_cyan"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Bottom Controls Area -->
    <LinearLayout
        android:id="@+id/bottomControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/scrim"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Result Summary (hidden during preview) -->
        <TextView
            android:id="@+id/tvResultSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:visibility="gone"
            tools:text="⚠ 2 anomalies detected" />

        <!-- Selected Node Indicator -->
        <TextView
            android:id="@+id/tvSelectedNode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            tools:text="Capturing for Node-01" />

        <!-- Buttons -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Capture State -->
            <ImageButton
                android:id="@+id/btnCapture"
                android:layout_width="@dimen/capture_button_size"
                android:layout_height="@dimen/capture_button_size"
                android:layout_gravity="center"
                android:background="@drawable/ic_circle"
                android:backgroundTint="@color/accent_cyan"
                android:src="@android:drawable/ic_menu_camera"
                app:tint="@color/text_on_accent" />

            <!-- Post-Capture State (Upload / Retake) -->
            <LinearLayout
                android:id="@+id/layoutPostCapture"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:visibility="gone"
                tools:visibility="visible">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRetake"
                    style="@style/BridgeSense.Button.Outlined"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/spacing_md"
                    android:text="@string/camera_retake" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUpload"
                    style="@style/BridgeSense.Button.Primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/camera_upload" />
            </LinearLayout>
        </FrameLayout>

    </LinearLayout>

    <!-- Loading Overlay -->
    <FrameLayout
        android:id="@+id/overlayLoading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B3000000"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <ProgressBar
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminateTint="@color/accent_cyan" />

            <TextView
                android:id="@+id/tvLoadingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/camera_analyzing"
                android:textColor="@color/accent_cyan" />
        </LinearLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
